# Rename this file to .env locally
# Do not share this file or upload it to GitHub.

# SMTP CREDENTIALS
SMTP_SERVER=smtp.zoho.in
SMTP_PORT=465
SMTP_EMAIL=your-email@example.com
SMTP_PASSWORD=your-app-password

# OPEN TRACKING (Google Apps Script pixel — see tracker.gs for setup)
TRACKER_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
CAMPAIGN_ID=bni_solar_apr_2026

# SENDER DETAILS (Used in Email Template)
SENDER_NAME=Your Full Name
SENDER_COMPANY=Your Company Name
SENDER_LINKEDIN=https://www.linkedin.com/in/yourprofile
SENDER_WHATSAPP=+910000000000
SENDER_WEBSITE=https://www.yourwebsite.com
SENDER_PHONE=+91 00000 00000
